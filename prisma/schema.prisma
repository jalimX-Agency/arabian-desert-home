generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Suite {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  longDescription String
  price       Int
  features    String
  image       String
  maxGuests   Int      @default(2)
  size        String
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    Booking[]
}

model Experience {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  longDescription String
  duration    String
  price       Int
  image       String
  category    String
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Booking {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String
  phone         String?
  suiteId       String
  suite         Suite    @relation(fields: [suiteId], references: [id])
  checkIn       DateTime
  checkOut      DateTime
  guests        Int      @default(2)
  experiences   String?
  specialReqs   String?
  status        String   @default("pending")
  totalAmount   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
